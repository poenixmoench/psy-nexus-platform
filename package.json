{
  "name": "psy-nexus-platform-root",
  "version": "1.0.0",
  "description": "Monorepo for Psy Nexus Platform",
  "scripts": {
    "start:dev": "docker-compose -f infrastructure/docker/docker-compose.yml up --build --force-recreate -d",
    "stop": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "build:backend": "docker-compose -f infrastructure/docker/docker-compose.yml build backend",
    "build:frontend": "docker-compose -f infrastructure/docker/docker-compose.yml build frontend"
  },
