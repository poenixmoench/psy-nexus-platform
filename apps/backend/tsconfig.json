{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@shared/basis-agent": ["../../libs/shared/basis-agent/src/index.ts"],
      "@shared/geometry": ["../../libs/shared/geometry/src/index.ts"],
      "@shared/config/*": ["../../packages/shared/src/config/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@shared/types/*": ["../../packages/shared/src/types/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../libs/shared/basis-agent/src/**/*",
    "../../libs/shared/geometry/src/**/*"
  ]
}
