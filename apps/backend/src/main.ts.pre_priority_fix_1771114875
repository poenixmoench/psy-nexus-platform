import "reflect-metadata";
import * as path from "path";
const moduleAlias = require("module-alias");

const projectRoot = "/root/psy-nexus-platform";
const sharedDist = path.join(projectRoot, "packages/shared/dist");

// Absolute Mapping-Dominanz
moduleAlias.addAliases({
  "@shared": sharedDist,
  // Hier biegen wir die TSC-generierten Relativpfade physisch um:
  "../../../packages/shared/src": sharedDist,
  "../../packages/shared/src": sharedDist,
  "../packages/shared/src": sharedDist
});

moduleAlias();

console.log('[Alias-Fix] Absolute Pfad-Autonomie für Shared-Dist aktiviert.');
console.log('[Alias-Fix] Ziel: ', sharedDist);
import { container } from 'tsyringe';
import express from 'express';
import http from 'http';
import cors from 'cors';
import { setupDIContainer } from './di/container';
import { SocketService } from './services/SocketService';
import apiRoutes from './routes/index';

async function bootstrap() {
  try {
    setupDIContainer();
    const app = express();
    app.use(cors({ origin: "*" }));
    app.use(express.json({ limit: '10mb' }));

    const server = http.createServer(app);
    const socketService = container.resolve(SocketService);
    
    // Audit-konform: init() statt initialize()
    socketService.init(server);

    app.use('/api', apiRoutes);

    const PORT = process.env.PORT || 3005;
    server.listen(PORT, () => {
      console.log(`🚀 Nexus-Backend stabilisiert auf Port ${PORT}`);
    });

    // Keep-alive für den Event-Loop
    setInterval(() => {}, 1000 * 60 * 60);

  } catch (error) {
    console.error('💥 Bootstrap-Fehler:', error);
    process.exit(1);
  }
}

bootstrap();
