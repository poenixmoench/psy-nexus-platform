import express from 'express';
import { createServer } from 'http';
import { setupSocket } from './socket-config';
import { DialogAgent } from './agents/DialogAgent';
import { askAIStream } from './services/AIService';

const app = express();
const httpServer = createServer(app);
const io = setupSocket(httpServer);
const dialogAgent = new DialogAgent();

app.get('/api/agents', (req, res) => {
  res.json([
    { name: 'ORION', role: 'Kommunikations-Assistent' },
    { name: 'PLAN-AGENT', role: 'Strukturierer' },
    { name: 'FRONTEND-MEISTER', role: 'HTML/Vue Coder' },
    { name: 'DESIGN-ALCHEMIST', role: 'CSS Master' },
    { name: 'BACKEND-ARCHITEKT', role: 'Server Master' },
    { name: 'QA-GURU', role: 'Quality Expert' },
    { name: 'OPTIMIERER', role: 'Performance Expert' },
    { name: 'DOKUMENTATION-AGENT', role: 'Knowledge Keeper' }
  ]);
});

io.on('connection', (socket) => {
  socket.on('agent-message', async (data: any) => {
    const agentName = data.agentName || 'ORION';
    const userMessage = data.message || data.text;

    try {
      dialogAgent.addUserMessage(userMessage);
      const context = dialogAgent.buildConversationContext();

      let fullText = '';
      await askAIStream(context, (chunk) => {
        fullText += chunk;
        socket.emit('agent-partial', { agent: agentName, text: fullText });
      }, agentName);

      dialogAgent.addAssistantMessage(fullText);
      socket.emit('agent-message', {
        agent: agentName,
        text: fullText,
        timestamp: new Date().toISOString()
      });
    } catch (err: any) {
      socket.emit('agent-error', { message: err.message });
    }
  });
});

httpServer.listen(3000, () => console.log('🚀 PSY-NEXUS: Multi-Agent Production Ready'));
