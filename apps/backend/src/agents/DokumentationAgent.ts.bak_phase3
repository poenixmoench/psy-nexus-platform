import { injectable, inject } from 'tsyringe';
import { BaseAgent } from '@shared/basis-agent/BaseAgent';
import { AIService } from '../services/AIService';

@injectable()
export class DokumentationAgent extends BaseAgent {
  public readonly name = 'DOKUMENTATION_AGENT';
  
  constructor(
    @inject('Logger') private logger: any,
    @inject(AIService) private aiService: AIService
  ) {
    super();
  }

  async processDelta(payload: any): Promise<any> {
    const query = payload.query || payload.message || "";
    console.log(`🚀 [${this.name}] Processing...\nQUERY: ${query.substring(0, 50)}...`);
    const result = await this.aiService.askAI(query, this.name);
    return {
      success: true,
      output: result,
      agentName: this.name,
      newTags: []
    };
  }
}
