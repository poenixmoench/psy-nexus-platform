const ws = ref<typeof agentWs | null>(null)

onMounted(async () => {
  try {
    await agentWs.connect()
    ws.value = agentWs

    agentWs.on('task:progress', (data: { taskId: string; progress: number; status: string }) => {
      const task = tasks.value.find(t => t.id === data.taskId)
      if (task) {
        task.progress = data.progress
        task.status = data.status
      }
    })

    agentWs.on('task:result', (data: { taskId: string; result: string }) => {
      const task = tasks.value.find(t => t.id === data.taskId)
      if (task) {
        task.result = data.result
        task.status = 'COMPLETED'
        task.progress = 100
      }
    })

    agentWs.on('task:error', (data: { taskId: string; error: string }) => {
      const task = tasks.value.find(t => t.id === data.taskId)
      if (task) {
        task.result = `Error: ${data.error}`
        task.status = 'FAILED'
      }
    })
  } catch (error) {
    console.error('❌ Failed to connect WebSocket:', error)
  }
})

onUnmounted(() => {
  if (ws.value) {
    agentWs.disconnect()
  }
})
